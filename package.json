{
  "name": "hotel-restaurant-minimart-site",
  "private": true,
  "description": "Firebase Hosting — HotelRestaurantMini-MartManagement app + documentation",
  "scripts": {
    "build": "bash scripts/build-public.sh",
    "sync": "bash scripts/sync-from-production.sh",
    "patch": "python3 scripts/patch-app-embed-docs.py",
    "serve": "npm run build && npx firebase emulators:start --only hosting",
    "deploy": "npm run build && firebase deploy --only hosting"
  },
  "devDependencies": {
    "firebase-tools": "^15.19.1"
  },
  "engines": {
    "node": ">=18"
  }
}
