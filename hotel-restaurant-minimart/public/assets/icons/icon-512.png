    this.columns = (opts.columns || []).slice();
    this.trackVisible = (opts.trackVisible === false) ? false : true;
    if (this.trackVisible && !this.columns.some(function (c) { return c && c.field === 'visible'; })) {
      this.columns = this.columns.concat([{
        field: 'visible',
        labelKey: 'grid.colVisible',
        label: 'Visible',
        width: '72px',
        filterable: true,
        format: function (v) {
          if (v === false) {
            return '<span class="status status-maintenance">' + (typeof t === 'function' ? t('grid.visibleNo') : 'No') + '</span>';
          }
          return (typeof t === 'function' ? t('grid.visibleYes') : 'Yes');
        }
