        const rc = this.rowClass ? (' ' + (this.rowClass(row) || '')) : '';
        const rh = (this.showHiddenRows && this.trackVisible && row && row.visible === false) ? ' xgrid-row-hidden' : '';
        html += `<tr class="${sel}${rc}${rh}" onclick="window._xg_${this.container.id}.selectRow(${globalIdx})">`;
        this.columns.forEach((col, ci) => {
          if (col.hidden) return;
