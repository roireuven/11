function i18nToast(key, params) { if (typeof t !== 'function' || typeof toast !== 'function') return; toast(t(key, params)); }
function daysBetween(a, b) { return Math.max(1, Math.ceil((new Date(b) - new Date(a)) / 86400000)); }

// ===== EXCEL-LIKE GRID ENGINE =====
function xgridColLabel(col) {
