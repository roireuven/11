function selectOpts(arr, sel) { return arr.map(v => '<option value="' + i18nOptEsc(v) + '"' + (v === sel ? ' selected' : '') + '>' + i18nOptEsc(v) + '</option>').join(''); }
function selectOptsLabeled(arr, sel, getLabel) {
