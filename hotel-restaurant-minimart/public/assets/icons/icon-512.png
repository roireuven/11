/* Demo bookings: none — add stays from Bookings; F&B sample is menu + store + guests only. */

function mergePosTransactionsIntoUnified() {
  if (!Array.isArray(posTransactions) || !Array.isArray(transactions)) return;
  const ids = new Set(transactions.map(t => t.transactionId).filter(Boolean));
  let added = 0;
  posTransactions.forEach(pt => {
    const tid = pt.transactionId;
    if (!tid || ids.has(tid)) return;
    ids.add(tid);
    const itemsRaw = pt.items || [];
    const items = itemsRaw.map(i => ({
      itemId: i.itemId || '',
      name: i.name,
      qty: i.qty,
      unitPrice: i.unitPrice,
      total: (parseFloat(i.unitPrice) || 0) * (parseInt(i.qty, 10) || 0),
      inventoryDeducted: false
    }));
    const sub = parseFloat(pt.subtotal);
    const taxAmt = parseFloat(pt.tax);
    const gtot = parseFloat(pt.grandTotal);
    transactions.push({
      id: pt.id || genId(),
      transactionId: tid,
      timestamp: pt.timestamp || new Date().toISOString(),
      source: pt.source || 'POS',
      orderId: '',
      roomNumber: pt.roomNumber != null ? String(pt.roomNumber) : '',
      guestName: pt.guestName || '',
      bookingId: pt.bookingId || '',
      items: items,
      subtotal: isNaN(sub) ? 0 : sub,
      taxRate: parseFloat(settings.surcharge) || 7,
      taxAmount: isNaN(taxAmt) ? 0 : taxAmt,
      grandTotal: isNaN(gtot) ? 0 : gtot,
      status: pt.status || 'Completed',
      paymentMethod: pt.paidBy || 'Cash',
      invoiceId: pt.invoiceId || '',
      staffName: pt.staffName || '',
      workPeriodId: pt.workPeriodId || ''
    });
    added++;
  });
  if (added > 0) save('transactions', transactions);
}
mergePosTransactionsIntoUnified();

// Take initial snapshots for auto-audit
['rooms','guests','bookings','services','invoices','accounts','tickets','messages','inventory','posTransactions','menuItems','restaurantOrders','martOpenOrders','posOpenOrders','restaurantTables','storeItems','serviceRequests','transactions','workPeriods'].forEach(k => {
  const d = {rooms,guests,bookings,services,invoices,accounts,tickets,messages,inventory,posTransactions,menuItems,restaurantOrders,martOpenOrders,posOpenOrders,restaurantTables,storeItems,serviceRequests,transactions,workPeriods}[k];
  if (Array.isArray(d)) _takeSnapshot(k, d);
});

