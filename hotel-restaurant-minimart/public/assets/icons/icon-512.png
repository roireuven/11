  if (t.indexOf('data:image/') === 0) return false;
  if (!/^https?:\/\//i.test(t)) return false;
  return /unsplash\.com|picsum\.|placekitten|loremflickr|lorempixel|pravatar|dummyimage|via\.placeholder|placehold\.co|fakeimg|pexels\.com|pixabay\.|freepik\.com|123rf|shutterstock|istock|gettyimages|depositphotos|dreamstime/i.test(t);
}
(function migrateMenuItemsStripStockImageUrl() {
  const MK = DB_KEY + 'menuStripStockHttpImgV1';
  try {
    if (String(localStorage.getItem(MK) || '') === '1') return;
  } catch (e) { return; }
  if (isAndroid) {
    try {
      if (String(HotelDB.getSetting('menuStripStockHttpImgV1') || '') === '1') return;
    } catch (e) {}
  }
