    var nRaw0 = sp.get('newsetup');
    var nsp0 = nRaw0 == null ? null : String(nRaw0);
    forceNew = nsp0 === '1' || nsp0 === '' || (nsp0 && String(nsp0).toLowerCase() === 'true') || (nsp0 && String(nsp0).toLowerCase() === 'yes') || (String(sp.get('setup') || '').toLowerCase() === 'new');
    if (forceNew) {
      clearNewSetupStorageFlags();
      if (typeof history !== 'undefined' && history.replaceState) {
        var u = new URL(location.href);
        u.searchParams.delete('newsetup');
        u.searchParams.delete('setup');
        history.replaceState({}, '', u.pathname + (u.search && u.search !== '?' ? u.search : '') + (u.hash || ''));
      }
    }
  } catch (e) {}
  if (!forceNew) {
    var epoch = null;
    try { epoch = localStorage.getItem(DB_KEY + 'appDataEpoch'); } catch (e) {}
    if (!epoch && isAndroid) { try { epoch = HotelDB.getSetting('appDataEpoch'); } catch (e) {} }
    if (String(epoch || '') !== String(V)) {
      var hadPrevEpoch = (epoch != null && String(epoch).replace(/^\s+|\s+$/g, '') !== '');
      if (hadPrevEpoch) { hotelWipeAllClientData(); }
      try { localStorage.setItem(DB_KEY + 'appDataEpoch', V); } catch (e) {}
      if (isAndroid) { try { HotelDB.saveSetting('appDataEpoch', V); } catch (e) {} }
    }
  }
  if (!hotelIsSetupComplete()) {
    var so2 = document.getElementById('setupOverlay');
    var lo2 = document.getElementById('loginOverlay');
    if (so2) so2.classList.remove('hidden');
    if (lo2) lo2.classList.add('hidden');
    return;
  }
  var so3 = document.getElementById('setupOverlay');
  var lo3 = document.getElementById('loginOverlay');
  if (so3) so3.classList.add('hidden');
  if (lo3) lo3.classList.remove('hidden');
})();

window.freshStartWithNewSetup = function () {
  var c1 = (typeof t === 'function' ? t('settings.freshStartConfirm') : 'This will delete ALL data and your system setup (email and password) on this device. Continue?');
  var c2 = (typeof t === 'function' ? t('settings.freshStartConfirm2') : 'This cannot be undone. Proceed?');
  if (typeof confirm === 'function' && !confirm(c1)) return;
  if (typeof confirm === 'function' && !confirm(c2)) return;
  hotelWipeAllClientData();
  location.reload();
};

const dbTableMap = {auditLog:'audit_log',bookingLog:'booking_log',inventoryLog:'inventory_log',posTransactions:'pos_transactions',menuItems:'menu_items',restaurantOrders:'restaurant_orders',martOpenOrders:'mart_open_orders',posOpenOrders:'pos_open_orders',storeItems:'store_items',serviceRequests:'service_requests',transactions:'transactions',workPeriods:'work_periods'};
function dbKey(key) { return dbTableMap[key] || key; }
/** Android stores each setting as TEXT; booleans/numbers must be coerced for correct UI logic. */
function normalizeSettingsFromAndroid() {
  if (!isAndroid || !settings) return;
  if (typeof settings.darkMode === 'string') {
    const s = settings.darkMode.trim().toLowerCase();
    settings.darkMode = s === 'true' || s === '1' || s === 'yes';
  }
  if (settings.maxGuests != null && typeof settings.maxGuests === 'string') {
    const m = parseInt(String(settings.maxGuests), 10);
    settings.maxGuests = (isNaN(m) || m < 1) ? defaultSettings.maxGuests : m;
  }
  if (settings.surcharge != null && typeof settings.surcharge === 'string') {
    const t = parseFloat(String(settings.surcharge));
    settings.surcharge = isNaN(t) ? defaultSettings.surcharge : t;
  }
}
function load(key, def) {
  if (isAndroid && key === 'restaurantTables') {
    try { const d = localStorage.getItem(DB_KEY + key); return d ? JSON.parse(d) : def; } catch (e) { return def; }
  }
  if (isAndroid) {
    try {
      if (key === 'settings') {
        const raw = HotelDB.getAllSettings();
        const obj = JSON.parse(raw || '{}');
        return Object.keys(obj).length > 0 ? obj : def;
      }
      const raw = HotelDB.getAll(dbKey(key));
      const arr = JSON.parse(raw || '[]');
      return arr.length > 0 ? arr.map(r => {
        if (r.services && typeof r.services === 'string') { try { r.services = JSON.parse(r.services); } catch(e) { r.services = []; } }
        if (key === 'martOpenOrders' && r.items && typeof r.items === 'string') { try { r.items = JSON.parse(r.items); } catch(e) { r.items = []; } }
        if (key === 'posOpenOrders' && r.items && typeof r.items === 'string') { try { r.items = JSON.parse(r.items); } catch(e) { r.items = []; } }
        if (r.price) r.price = Number(r.price);
        if (r.number) r.number = Number(r.number);
        if (r.floor) r.floor = Number(r.floor);
        if (r.maxGuests) r.maxGuests = Number(r.maxGuests);
        if (r.visits) r.visits = Number(r.visits);
        if (r.nights) r.nights = Number(r.nights);
        if (r.roomCharge) r.roomCharge = Number(r.roomCharge);
        if (r.serviceCharge) r.serviceCharge = Number(r.serviceCharge);
        if (r.total) r.total = Number(r.total);
        if (r.roomNumber) r.roomNumber = Number(r.roomNumber);
        return r;
      }) : def;
    } catch(e) { return def; }
  }
  try { const d = localStorage.getItem(DB_KEY + key); return d ? JSON.parse(d) : def; } catch(e) { return def; }
}

/** Compact local timestamp: yyyyMMddHHmmss (GetDate-style, no separators). */
function ymdHmsFromDate(d) {
  if (!(d instanceof Date) || isNaN(d.getTime())) d = new Date();
  const z = function (n) { n = n | 0; return n < 10 ? '0' + n : String(n); };
  return String(d.getFullYear()) + z(d.getMonth() + 1) + z(d.getDate()) + z(d.getHours()) + z(d.getMinutes()) + z(d.getSeconds());
}
function ymdHmsNow() { return ymdHmsFromDate(new Date()); }
function _rowStripStamps(r) {
  if (!r || typeof r !== 'object' || Array.isArray(r)) return r;
  const c = Object.assign({}, r);
  delete c.CreatedDate;
  delete c.EditDate;
  return c;
}
function _readPrevArrayForStamp(key) {
  try {
    if (!isAndroid) {
      const d = localStorage.getItem(DB_KEY + key);
      if (!d) return null;
      return JSON.parse(d);
    }
    if (typeof HotelDB === 'undefined' || !HotelDB.getAll) return null;
    return JSON.parse(HotelDB.getAll(dbKey(key)) || '[]');
  } catch (e) { return null; }
}
function _readPrevSettingsForStamp() {
  try {
    if (!isAndroid) {
      const d = localStorage.getItem(DB_KEY + 'settings');
      return d ? JSON.parse(d) : null;
    }
    const s = HotelDB.getAllSettings();
    if (s == null || String(s).trim() === '') return null;
    return JSON.parse(s);
  } catch (e) { return null; }
}
function _stampSettingsObject(data) {
  if (!data || typeof data !== 'object' || Array.isArray(data)) return;
  const now = ymdHmsNow();
  const rawPrev = _readPrevSettingsForStamp();
  if (!rawPrev || (typeof rawPrev === 'object' && Object.keys(rawPrev).length === 0)) {
    if (data.CreatedDate == null || data.CreatedDate === '') data.CreatedDate = now;
    data.EditDate = now;
    return;
  }
  const a = _rowStripStamps(data);
  const b = _rowStripStamps(rawPrev);
  if (JSON.stringify(a) === JSON.stringify(b)) {
    if (data.CreatedDate == null || data.CreatedDate === '') data.CreatedDate = (rawPrev.CreatedDate != null && rawPrev.CreatedDate !== '') ? rawPrev.CreatedDate : now;
    if (data.EditDate == null || data.EditDate === '') data.EditDate = (rawPrev.EditDate != null && rawPrev.EditDate !== '') ? rawPrev.EditDate : now;
  } else {
    if (data.CreatedDate == null || data.CreatedDate === '') data.CreatedDate = (rawPrev.CreatedDate != null && rawPrev.CreatedDate !== '') ? rawPrev.CreatedDate : now;
    data.EditDate = now;
  }
}
function _applyRowStampsToArray(key, data) {
  if (!Array.isArray(data)) return;
  const now = ymdHmsNow();
  const prevList = _readPrevArrayForStamp(key);
  if (!Array.isArray(prevList)) {
    for (var i0 = 0; i0 < data.length; i0++) {
      var r0 = data[i0];
      if (!r0 || r0.id == null || r0.id === '') continue;
      if (r0.CreatedDate == null || r0.CreatedDate === '') r0.CreatedDate = now;
      r0.EditDate = now;
    }
    return;
  }
  const prevById = new Map();
  for (var p = 0; p < prevList.length; p++) { var pr = prevList[p]; if (pr && pr.id != null) prevById.set(pr.id, pr); }
  for (var i = 0; i < data.length; i++) {
    var r = data[i];
    if (!r || r.id == null || r.id === '') continue;
    var pRow = prevById.get(r.id);
    if (!pRow) {
      r.CreatedDate = (r.CreatedDate != null && r.CreatedDate !== '') ? r.CreatedDate : now;
      r.EditDate = now;
    } else {
      r.CreatedDate = (pRow.CreatedDate != null && pRow.CreatedDate !== '') ? pRow.CreatedDate : ((r.CreatedDate != null && r.CreatedDate !== '') ? r.CreatedDate : now);
      const same = JSON.stringify(_rowStripStamps(pRow)) === JSON.stringify(_rowStripStamps(r));
      r.EditDate = same ? ((pRow.EditDate != null && pRow.EditDate !== '') ? pRow.EditDate : (r.EditDate != null && r.EditDate !== '' ? r.EditDate : now)) : now;
    }
  }
}

const _snapshots = {};
const _noAutoAudit = {auditLog:1,bookingLog:1,inventoryLog:1,settings:1};
function _takeSnapshot(key, data) {
  if (_noAutoAudit[key] || !Array.isArray(data)) return;
  _snapshots[key] = new Map(data.map(r => [r.id, JSON.stringify(r)]));
}
function _autoAudit(key, data) {
  if (_noAutoAudit[key] || !Array.isArray(data) || !_snapshots[key]) return;
  const prev = _snapshots[key];
  const curr = new Map(data.map(r => [r.id, JSON.stringify(r)]));
  const user = (typeof currentUser!=='undefined' && currentUser) ? currentUser.name : (typeof currentRole!=='undefined' ? currentRole : 'System');
  curr.forEach((json, id) => {
    if (!prev.has(id)) {
      const r = JSON.parse(json);
      auditLog.push({id:genId(),timestamp:new Date().toISOString(),module:key,user:user,action:'Insert',itemId:id,details:r.name||r.guestName||r.bookingId||r.roomNumber||r.itemName||r.label||r.invoiceNumber||r.transactionId||''});
    } else if (prev.get(id) !== json) {
      const r = JSON.parse(json);
      auditLog.push({id:genId(),timestamp:new Date().toISOString(),module:key,user:user,action:'Update',itemId:id,details:r.name||r.guestName||r.bookingId||r.roomNumber||r.itemName||r.label||r.invoiceNumber||r.transactionId||''});
    }
  });
  prev.forEach((json, id) => {
    if (!curr.has(id)) {
      const r = JSON.parse(json);
      auditLog.push({id:genId(),timestamp:new Date().toISOString(),module:key,user:user,action:'Delete',itemId:id,details:r.name||r.guestName||r.bookingId||r.roomNumber||r.itemName||r.label||r.invoiceNumber||r.transactionId||''});
    }
  });
  if (auditLog.length > 2000) auditLog = auditLog.slice(-2000);
  _snapshots[key] = curr;
  if (isAndroid) { try { HotelDB.upsert('audit_log', JSON.stringify(auditLog[auditLog.length-1])); } catch(e){} }
  else { try { localStorage.setItem(DB_KEY + 'auditLog', JSON.stringify(auditLog)); } catch(e){} }
}
function save(key, data) {
  try {
    if (key === 'settings' && data && typeof data === 'object' && !Array.isArray(data)) {
      _stampSettingsObject(data);
    } else if (Array.isArray(data)) {
      _applyRowStampsToArray(key, data);
    }
  } catch (eSt) { try { console.warn('CreatedDate/EditDate stamp', key, eSt); } catch (e2) {} }
  _autoAudit(key, data);
  if (isAndroid && key === 'restaurantTables') {
    try { localStorage.setItem(DB_KEY + key, JSON.stringify(data)); } catch (e) {}
    return;
  }
  if (isAndroid) {
    try {
      if (key === 'settings') {
        const obj = data;
        for (const [k, v] of Object.entries(obj)) { HotelDB.saveSetting(k, String(v)); }
        return;
      }
      HotelDB.deleteAll(dbKey(key));
      const toSave = data.map(r => {
        const copy = {...r};
        if (copy.services && Array.isArray(copy.services)) copy.services = JSON.stringify(copy.services);
        if (key === 'martOpenOrders' && copy.items && Array.isArray(copy.items)) copy.items = JSON.stringify(copy.items);
        if (key === 'posOpenOrders' && copy.items && Array.isArray(copy.items)) copy.items = JSON.stringify(copy.items);
        return copy;
      });
      HotelDB.upsertAll(dbKey(key), JSON.stringify(toSave));
    } catch(e) { console.error('DB save error', e); }
    if (key === 'restaurantOrders') {
      try { window.dispatchEvent(new CustomEvent('hotel-sync-restaurantOrders')); } catch (e) {}
    }
    return;
  }
  localStorage.setItem(DB_KEY + key, JSON.stringify(data));
  if (key === 'restaurantOrders') {
    try { window.dispatchEvent(new CustomEvent('hotel-sync-restaurantOrders')); } catch (e) {}
  }
}

function saveOne(key, row) {
  if (isAndroid) {
    try {
      const copy = {...row};
      const now = ymdHmsNow();
      const prevList = _readPrevArrayForStamp(key) || [];
      const p = prevList.find(function (x) { return x && x.id === copy.id; });
      if (!p) {
        if (copy.CreatedDate == null || copy.CreatedDate === '') copy.CreatedDate = now;
        copy.EditDate = now;
      } else {
        copy.CreatedDate = (p.CreatedDate != null && p.CreatedDate !== '') ? p.CreatedDate : ((copy.CreatedDate != null && copy.CreatedDate !== '') ? copy.CreatedDate : now);
        const same = JSON.stringify(_rowStripStamps(p)) === JSON.stringify(_rowStripStamps(copy));
        copy.EditDate = same ? ((p.EditDate != null && p.EditDate !== '') ? p.EditDate : (copy.EditDate || now)) : now;
      }
      if (copy.services && Array.isArray(copy.services)) copy.services = JSON.stringify(copy.services);
      HotelDB.upsert(dbKey(key), JSON.stringify(copy));
    } catch(e) { console.error('DB saveOne error', e); }
    return;
  }
}

function deleteOne(key, id) {
  if (isAndroid) {
    try { HotelDB.deleteRow(dbKey(key), id); } catch(e) { console.error('DB deleteOne error', e); }
  }
}

function genId() { return Date.now().toString(36) + Math.random().toString(36).substr(2, 5); }
function escAttr(s) { return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }
function escHtml(s) { return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;'); }
var PRODUCT_IMAGE_FILE_MAX_BYTES = 700000;
/** ctx: menuAdd | menuEdit | storeAdd | storeEdit | invAdd | invEdit */
window.onProductImageFilePicked = function(ctx, fileInput) {
  var f = fileInput && fileInput.files && fileInput.files[0];
  if (!f) return;
  if (!/^image\//i.test(f.type)) { if (typeof toast === 'function') toast(t('msg.imageNotImage')); try { fileInput.value = ''; } catch (e) {} return; }
  if (f.size > PRODUCT_IMAGE_FILE_MAX_BYTES) { if (typeof toast === 'function') toast(t('msg.imageTooLarge')); try { fileInput.value = ''; } catch (e) {} return; }
  var r = new FileReader();
  r.onload = function() {
    var data = r.result;
    if (typeof data !== 'string') return;
    var map = {
      menuAdd: { data: 'mMiImgData', url: 'mMiImg', prev: 'mMiImgPreview' },
      menuEdit: { data: 'eMiImgData', url: 'eMiImg', prev: 'eMiImgPreview' },
      storeAdd: { data: 'mSiImgData', url: 'mSiImg', prev: 'mSiImgPreview' },
      storeEdit: { data: 'eSiImgData', url: 'eSiImg', prev: 'eSiImgPreview' },
      invAdd: { data: 'mInvImgData', url: 'mInvImg', prev: 'mInvImgPreview' },
      invEdit: { data: 'eInvImgData', url: 'eInvImg', prev: 'eInvImgPreview' }
    };
    var M = map[ctx]; if (!M) return;
    var h = document.getElementById(M.data); if (h) h.value = data;
    var u = document.getElementById(M.url); if (u) u.value = '';
    var p = document.getElementById(M.prev); if (p) { p.src = data; p.style.display = ''; }
  };
  r.onerror = function() { if (typeof toast === 'function') toast(t('msg.imageNotImage')); };
  r.readAsDataURL(f);
};
function clearProductImagePreview(ctx) {
  var map = {
    menuAdd: { data: 'mMiImgData', prev: 'mMiImgPreview', file: 'mMiImgFile' },
    menuEdit: { data: 'eMiImgData', prev: 'eMiImgPreview', file: 'eMiImgFile' },
    storeAdd: { data: 'mSiImgData', prev: 'mSiImgPreview', file: 'mSiImgFile' },
    storeEdit: { data: 'eSiImgData', prev: 'eSiImgPreview', file: 'eSiImgFile' },
    invAdd: { data: 'mInvImgData', prev: 'mInvImgPreview', file: 'mInvImgFile' },
    invEdit: { data: 'eInvImgData', prev: 'eInvImgPreview', file: 'eInvImgFile' }
  };
  var M = map[ctx]; if (!M) return;
  var h = document.getElementById(M.data); if (h) h.value = '';
  var p = document.getElementById(M.prev); if (p) { try { p.removeAttribute('src'); } catch (e) {} p.style.display = 'none'; }
  var fi = document.getElementById(M.file); if (fi) try { fi.value = ''; } catch (e2) {}
}
function persistCatalogAfterFullWipe(keepMenuArr, keepStoreArr) {
  try {
    if (typeof isAndroid !== 'undefined' && isAndroid) {
      try { HotelDB.deleteAll('menu_items'); HotelDB.upsertAll('menu_items', JSON.stringify((keepMenuArr || []).map(function (r) { return Object.assign({}, r); }))); } catch (e) {}
      try { HotelDB.deleteAll('store_items'); HotelDB.upsertAll('store_items', JSON.stringify((keepStoreArr || []).map(function (r) { return Object.assign({}, r); }))); } catch (e2) {}
    } else {
      try { localStorage.setItem(DB_KEY + 'menuItems', JSON.stringify(keepMenuArr || [])); } catch (e3) {}
      try { localStorage.setItem(DB_KEY + 'storeItems', JSON.stringify(keepStoreArr || [])); } catch (e4) {}
    }
  } catch (e) {}
}
