    if (!m) return;
    if (m.icon != null && String(m.icon).trim() !== '') return;
    m.icon = inferMenuItemIconFromNameAndCategory(m.name, m.category, m.description);
    ch = true;
  });
  if (ch) { try { save('menuItems', menuItems); } catch (e) {} }
  try { localStorage.setItem(MK, '1'); } catch (e) {}
  if (isAndroid) { try { HotelDB.saveSetting('menuBackfillIconV1', '1'); } catch (e) {} }
})();
/** One-time: clear legacy demo rows so Bookings, Invoices, and Inventory grids start empty (v2: strip menu/store stock links). */
(function migrateEmptyBookInvInvSampleGrids() {
