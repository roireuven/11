function normalizeHotelCurrency() {
  var labels = getCurrencyLabels();
  if (labels.length === 0) return false;
  if (labels.indexOf(settings.currency) < 0) {
    settings.currency = labels[0];
    save('settings', settings);
    return true;
  }
  return false;
}
window.setHotelCurrencyLak = function() {
  var labels = getCurrencyLabels();
  var lak = null;
  for (var i = 0; i < labels.length; i++) { if (String(labels[i]).indexOf('LAK') >= 0) { lak = labels[i]; break; } }
  if (!lak) { if (typeof toast === 'function' && typeof t === 'function') toast(t('msg.lakMissing')); return; }
  settings.currency = lak;
  try { localStorage.setItem('hotel_lastSuggestLak', '1'); } catch (e) {}
  save('settings', settings);
  logAudit('Update', 'Settings', 'Hotel currency set to Lao kip (LAK)');
  if (typeof renderSettings === 'function' && document.getElementById('page-settings') && document.getElementById('page-settings').classList.contains('active')) renderSettings();
  if (typeof toast === 'function' && typeof t === 'function') toast(t('msg.hotelCurrency', { code: lak }));
};
