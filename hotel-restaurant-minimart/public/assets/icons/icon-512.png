/** One emoji (or short unicode) for restaurant menu when no custom icon / photo. */
function inferMenuItemIconFromNameAndCategory(name, category, description) {
  const n = (String(name || '') + ' ' + String(description || '')).toLowerCase();
  const c = String(category || '').toLowerCase();
  if (/\b(muffin|tiramisu|dessert|mousse|brownie|sorbet|gelato|pudding)\b/.test(n) || c.indexOf('dessert') >= 0) return '\uD83C\uDF6E';
  if (/\b(ice lao|iced|ice lemon|milkshake|milk shake|oreo shake|mango shake|banana shake)\b/.test(n)) return '\uD83E\uDDC3';
  if (/\bice\s+(coffee|lao|lipton|oval|ovaltine)\b/.test(n) || n.indexOf('ice lemon') >= 0) return '\uD83E\uDDC3';
  if (/\b(shake|lassi|smoothie|ovaltine)\b/.test(n)) return '\uD83E\uDDC3';
  if (/\b(juice|lemon|orange|apple|mango|banana|pineapple|lime|cooler|cool)\b/.test(n) && (/\b(juice|shake|smooth|cooler|cool|glass)\b/.test(n) || n.indexOf('(2 gl') >= 0)) return '\uD83C\uDF79';
  if (/\b(mineral water|sparkling|soda|pepsi|mirinda|7-up|7up|coca|soft drink|bottle|can|cola)\b/.test(n) || c.indexOf('beverage') >= 0) return '\uD83E\uDDCB';
  if (/\b(nescaf|coffee|espresso|latte|cappuc|brew black)\b/.test(n) && n.indexOf('ice') < 0) return '\u2615';
  if (/\b(tea|chai|lipton|masala tea|milk tea|hot lem)\b/.test(n) && n.indexOf('ice lem') < 0 && n.indexOf('ice lao') < 0) return '\uD83C\uDF75';
  if (/\b(beer|lager|pint|brew)\b/.test(n)) return '\uD83C\uDF7A';
  if (/\b(wine|vino|rose|sparkling w)\b/.test(n)) return '\uD83C\uDF77';
  if (/\b(raita|yogurt drink)\b/.test(n)) return '\uD83E\uDDC3';
  if (/\b(french fries|fries|wedge|chip)\b/.test(n) && n.indexOf('gobi') < 0) return '\uD83C\uDF5F';
  if (/\b(samosa|spring roll|gyoza)\b/.test(n)) return '\uD83E\uDDF5';
  if (/\b(prawn|shrimp|lobster|seafood pl)\b/.test(n) || n.indexOf('prawn') >= 0) return '\uD83E\uDD90';
  if (/\b(fish|tuna|salmon|sea bass)\b/.test(n) && n.indexOf('dish') < 0) return '\uD83D\uDC1F';
  if (/\b(beef|lamb|mutton|pork|steak)\b/.test(n) && n.indexOf('chicken') < 0) return '\uD83E\uDD69';
  if (/\bpaneer\b/.test(n)) return '\uD83E\uDDC0';
