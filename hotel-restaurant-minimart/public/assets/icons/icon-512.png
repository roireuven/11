  },
  "setup": {
    "h1": "Welcome to HotelRestaurantMini-MartManagement",
    "version": "v2.0 — First-Time Setup",
    "welcome": "Welcome to HotelRestaurantMini-MartManagement — a complete hotel, restaurant, minimart, and point-of-sale system. Create your account below to get started.",
    "createAccount": "Create Your Account",
    "createAccountP": "This is your personal login. All devices that sign in with the same email and password will synchronize data automatically.",
    "email": "Email",
    "password": "Password",
    "emailPh": "your.email@company.com",
    "passwordPh": "Create a password",
    "step1Title": "Sign In Anywhere",
    "step1P": "Use your email and password to log in on any device. Your data follows you.",
    "step2Title": "Sync Across Devices",
    "step2P": "Install the app on multiple phones or tablets. All devices with the same email share rooms, bookings, guests, and invoices.",
    "step3Title": "Role-Based Access",
    "step3P": "After first login, assign staff roles (Admin, Manager, Reception, Housekeeper, Restaurant, Kitchen). Restaurant takes restaurant orders; Kitchen sees the live order queue (prep, ready, served) without room billing functions.",
    "createBtn": "Create account & get started"
  },
  "pos": {
    "itemsHeader": "Items",
    "itemsCountHint": "{n} in stock for sale",
    "addItemBtn": "Add inventory item"
  }
}
  </script>
  <div id="setupOverlay">
    <div class="setup-card">
      <div class="setup-logo" style="font-size:2.5rem;background:linear-gradient(135deg,#1a3a5c,#1a73e8);color:#fff;width:64px;height:64px;border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 0.5rem;font-weight:700;">R</div>
      <h1 data-i18n="setup.h1">Welcome to HotelRestaurantMini-MartManagement</h1>
      <div class="setup-ver" data-i18n="setup.version">v2.0 — First-Time Setup</div>

      <div style="margin:0.6rem auto 0.2rem;max-width:520px;padding:0.6rem 0.75rem;border-radius:12px;background:rgba(26,115,232,0.12);border:1px solid rgba(26,115,232,0.35);color:#0a2a4a;font-weight:700;font-size:0.85rem;line-height:1.35;text-align:center;">
        Setup not done yet — please create your system email and password below.
      </div>

      <div class="setup-welcome" data-i18n="setup.welcome">
        Welcome to HotelRestaurantMini-MartManagement — a complete hotel, restaurant, minimart, and point-of-sale system. Create your account below to get started.
      </div>

      <div class="setup-step">
        <span class="step-num">1</span><span class="step-title" data-i18n="setup.step1Title">Sign In Anywhere</span>
        <p data-i18n="setup.step1P">Use your email and password to log in on any device. Your data follows you.</p>
      </div>

      <div class="setup-step">
        <span class="step-num">2</span><span class="step-title" data-i18n="setup.step2Title">Sync Across Devices</span>
        <p data-i18n="setup.step2P">Install the app on multiple phones or tablets. All devices with the same email share rooms, bookings, guests, and invoices.</p>
      </div>

      <div class="setup-step">
        <span class="step-num">3</span><span class="step-title" data-i18n="setup.step3Title">Role-Based Access</span>
        <p data-i18n="setup.step3P">After first login, assign staff roles. Restaurant takes restaurant orders; Kitchen sees the live order queue (prep, ready, served) without room billing.</p>
      </div>

      <div class="setup-email-section" style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid #e0e0e0;">
        <h3 data-i18n="setup.createAccount">Create Your Account</h3>
        <p data-i18n="setup.createAccountP">This is your personal login. All devices that sign in with the same email and password will synchronize data automatically.</p>
        <div class="form-group">
          <label style="color:#1a73e8;font-weight:600;" data-i18n="setup.email">Email</label>
          <input type="email" class="form-control" id="setupEmail" data-i18n-placeholder="setup.emailPh" placeholder="your.email@company.com" style="font-size:1rem;padding:0.7rem;">
        </div>
        <div class="form-group" style="margin-bottom:0;">
          <label style="color:#1a73e8;font-weight:600;" data-i18n="setup.password">Password</label>
          <input type="password" class="form-control" id="setupPassword" data-i18n-placeholder="setup.passwordPh" placeholder="Create a password" style="font-size:1rem;padding:0.7rem;">
        </div>
      </div>

      <button type="button" class="btn btn-primary btn-setup" id="btnCompleteSetup" aria-label="Create account and get started" onclick="(function(ev){if(ev)ev.stopPropagation();try{var c=window.completeSetup;if(typeof c==='function')c();else{var s=document.getElementById('setupError');if(s)s.textContent='Setup handler missing. Press Ctrl+F5 to reload.';}}catch(ex){var e2=document.getElementById('setupError');if(e2)e2.textContent=(ex&amp;&amp;ex.message)?String(ex.message):'Error';}return false;})(event)"><span data-i18n="setup.createBtn">Create Account &amp; Get Started</span></button>
      <div id="setupError" style="color:#e74c3c;font-size:0.85rem;margin-top:0.5rem;min-height:1.2em;"></div>
      <p class="login-tap-hint" style="text-align:center;margin:1rem 0 0;font-size:0.7rem;color:#6c757d;line-height:1.4;">Already have access? <button type="button" class="btn btn-sm btn-outline" style="min-height:36px;vertical-align:middle;" id="linkBackToSignIn" onclick="(function(){var s=document.getElementById('setupOverlay');var l=document.getElementById('loginOverlay');if(s){s.classList.add('hidden');}if(l){l.classList.remove('hidden');}})()">Back to sign in (demo)</button></p>
    </div>
  </div>

  <div id="loginOverlay" class="hidden">
    <div class="login-card">
      <div class="login-logo" style="font-size:2rem;background:linear-gradient(135deg,#1a3a5c,#1a73e8);color:#fff;width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 0.35rem;font-weight:700;">R</div>
      <h1 data-i18n="login.title">HotelRestaurantMini-MartManagement</h1>
      <p class="login-sub" data-i18n="login.subtitle">Sign in to manage the restaurant, hotel, and minimart</p>
      <div class="form-group"><label data-i18n="login.username">Username (Email)</label><input type="text" class="form-control" id="loginUsername" data-i18n-placeholder="login.usernameExPh" placeholder="e.g. admin@hotel.com" value="admin@hotel.com" autocomplete="username" inputmode="email" style="text-transform:lowercase;" oninput="this.value=this.value.toLowerCase()"></div>
      <div class="form-group"><label data-i18n="login.password">Password</label><input type="password" class="form-control" id="loginPassword" data-i18n-placeholder="login.passwordPh" placeholder="Enter password" value="1234"></div>
      <div class="form-group" style="margin-top:0.5rem;" id="loginLangRow">
        <label for="loginLocaleSelect" data-i18n="settings.appLanguage" style="font-size:0.9rem;font-weight:700;color:var(--text);">Interface language</label>
        <select id="loginLocaleSelect" class="form-control login-locale-sel" data-locale-select="1" data-native-select="1" onchange="setAppLocale(this.value)">
          <option value="en" selected>English</option>
        </select>
        <p style="font-size:0.7rem;color:#999;margin:0.35rem 0 0;line-height:1.35;" data-i18n="settings.languageHint">Applies to labels on this screen and the app after sign in.</p>
      </div>
      <button type="button" class="btn btn-primary btn-login" id="btnDoLogin" aria-label="Sign in" onclick="(function(ev){if(ev)ev.stopPropagation();try{var f=window.doLogin;if(typeof f!=='function'){var s=document.getElementById('loginError');if(s)s.textContent='Sign in not ready. Press Ctrl+F5 to reload.';return;}f();}catch(ex){var e2=document.getElementById('loginError');if(e2)e2.textContent=(ex&amp;&amp;ex.message)?String(ex.message):'Error';}return false;})(event)"><span data-i18n="login.signIn">Sign In</span></button>
      <div class="login-error" id="loginError"></div>
      <div class="login-creds">
        <h3 data-i18n="login.demoCredentials">Demo Credentials</h3>
        <table>
          <thead><tr><th data-i18n="login.role">Role</th><th data-i18n="login.emailUser">Email (Username)</th><th data-i18n="login.pwd">PWD</th></tr></thead>
          <tbody>
            <tr data-i18n-tip="login.tipAdmin" data-tip=""><td class="cred-role"><span class="cred-ico" aria-hidden="true">&#9670;</span> <span data-i18n="login.roleAdmin">Admin</span></td><td class="cred-email" onclick="document.getElementById('loginUsername').value=this.textContent">admin@hotel.com</td><td class="cred-pw">1234</td></tr>
            <tr data-i18n-tip="login.tipManager" data-tip=""><td class="cred-role"><span class="cred-ico" aria-hidden="true">&#9632;</span> <span data-i18n="login.roleManager">Manager</span></td><td class="cred-email" onclick="document.getElementById('loginUsername').value=this.textContent">mike@hotel.com</td><td class="cred-pw">1234</td></tr>
            <tr data-i18n-tip="login.tipReception" data-tip=""><td class="cred-role"><span class="cred-ico" aria-hidden="true">&#9679;</span> <span data-i18n="login.roleReception">Reception</span></td><td class="cred-email" onclick="document.getElementById('loginUsername').value=this.textContent">jane@hotel.com</td><td class="cred-pw">1234</td></tr>
            <tr data-i18n-tip="login.tipHousekeeper" data-tip=""><td class="cred-role"><span class="cred-ico" aria-hidden="true">&#9633;</span> <span data-i18n="login.roleHousekeeper">Housekeeper</span></td><td class="cred-email" onclick="document.getElementById('loginUsername').value=this.textContent">tom@hotel.com</td><td class="cred-pw">1234</td></tr>
            <tr data-i18n-tip="login.tipRestaurant" data-tip=""><td class="cred-role"><span class="cred-ico" aria-hidden="true">&#9650;</span> <span data-i18n="login.roleRestaurant">Restaurant</span></td><td class="cred-email" onclick="document.getElementById('loginUsername').value=this.textContent">restaurant@hotel.com</td><td class="cred-pw">1234</td></tr>
            <tr data-i18n-tip="login.tipKitchen" data-tip=""><td class="cred-role"><span class="cred-ico" aria-hidden="true">&#9660;</span> <span data-i18n="login.roleKitchen">Kitchen</span></td><td class="cred-email" onclick="document.getElementById('loginUsername').value=this.textContent">kitchen@hotel.com</td><td class="cred-pw">1234</td></tr>
          </tbody>
        </table>
        <p class="login-tap-hint" style="text-align:center;margin-top:0.4rem;font-size:0.68rem;color:#999;line-height:1.35;" data-i18n="login.tapEmail">Tap an email to auto-fill the username field</p>
        <p class="login-tap-hint" style="text-align:center;margin-top:0.5rem;">
        <button type="button" class="btn btn-outline" id="btnFirstTimeSetup" style="width:100%;max-width:100%;min-height:44px;font-size:0.9rem;" onclick="(function(){try{var u=new URL(window.location.href);u.searchParams.set('newsetup','1');location.replace(u.toString());}catch(e){location.href=(location.pathname||'/')+'?newsetup=1'+(location.hash||'');}})()">Start first-time setup (email + password)</button>
      </p>
        <p class="login-tap-hint" style="text-align:center;margin-top:0.35rem;font-size:0.65rem;color:#7f8c8d;line-height:1.35;">
          <a href="?newsetup=1" id="linkFirstTimeSetup" data-newsetup="1" style="color:#1a73e8;font-weight:600;">New setup</a> (system email + password) &mdash; one browser only. You can also add <code style="font-size:0.6rem;">?newsetup=1</code> to the address bar.
        </p>
      </div>
    </div>
  </div>
  <script>
  /* Before nisha1. ?newsetup=1 = clear setup only (keeps data). If appDataEpoch in storage differs from app-setup-version meta, full wipe (upgrade deploy gate). If epoch was never set, only stamp epoch — do not wipe (first load / just after Create Account). */
  (function () {
    window.hotelBootUrlParams = function () {
      try {
        var out = new URLSearchParams();
        var s = (typeof location !== 'undefined' && location.search) ? String(location.search) : '';
        if (s && s.length > 1) { new URLSearchParams(s).forEach(function (v, k) { out.set(k, v); }); }
        var h = (typeof location !== 'undefined' && location.hash) ? String(location.hash) : '';
        var qm = h.indexOf('?');
        if (qm >= 0) { new URLSearchParams(h.slice(qm)).forEach(function (v, k) { out.set(k, v); }); }
        return out;
      } catch (e) {}
      return new URLSearchParams();
    };
    function hotelEmailNamespace(email) {
      var s = String(email || '').toLowerCase().trim();
      var h = 0;
      for (var i = 0; i < s.length; i++) { h = ((h << 5) - h) + s.charCodeAt(i); h |= 0; }
      return 'ns' + (h >>> 0).toString(36);
    }
    function hotelBootStoragePrefix() {
      try {
        var ns = localStorage.getItem('hotel_mgr_dataNamespace');
        if (ns && String(ns).trim().length >= 2) return 'hotel_mgr_' + String(ns).trim() + '_';
      } catch (e) {}
      return 'hotel_mgr_';
    }
    var K = hotelBootStoragePrefix();
    function hotelGenIdEarly() { return Date.now().toString(36) + Math.random().toString(36).substr(2, 5); }
    /** Self-contained so Create Account works even if the main bundle (after nisha1) throws or never finishes. */
    function hotelCompleteSetupEarly() {
      var isAn0 = typeof HotelDB !== 'undefined';
      var meta0 = document.querySelector('meta[name="app-setup-version"]');
      var ver0 = (meta0 && meta0.getAttribute('content')) ? String(meta0.getAttribute('content')).replace(/^\s+|\s+$/g, '') : '1';
      var err0 = document.getElementById('setupError');
      var e0 = document.getElementById('setupEmail');
      var p0 = document.getElementById('setupPassword');
      if (!e0 || !p0) { if (err0) err0.textContent = 'Form not ready. Refresh the page (Ctrl+F5).'; return; }
      var email0 = (e0.value || '').trim();
      var pass0 = p0.value || '';
      if (!email0 || email0.indexOf('@') < 0) { if (err0) err0.textContent = 'Please enter a valid email address'; return; }
      if (!pass0 || pass0.length < 4) { if (err0) err0.textContent = 'Password must be at least 4 characters'; return; }
      var ns0 = hotelEmailNamespace(email0);
      try { localStorage.setItem('hotel_mgr_dataNamespace', ns0); } catch (e) {}
      K = 'hotel_mgr_' + ns0 + '_';
      try {
        localStorage.setItem(K + 'setupEmail', email0);
        localStorage.setItem(K + 'setupPassword', pass0);
        localStorage.setItem(K + 'setupDone', '1');
        localStorage.setItem(K + 'setupVersion', ver0);
      } catch (e) {
        if (err0) err0.textContent = 'Storage blocked. Allow site data (cookies) for this site, then try again.';
        return;
      }
      if (isAn0) {
        try { HotelDB.saveSetting('setupEmail', email0); HotelDB.saveSetting('setupPassword', pass0); HotelDB.saveSetting('setupDone', '1'); HotelDB.saveSetting('setupVersion', ver0); } catch (e1) {}
      }
      var acc0 = null;
      try { acc0 = JSON.parse(localStorage.getItem(K + 'accounts') || 'null'); } catch (e) { acc0 = null; }
      if (isAn0) {
        try { var rA = HotelDB.getAll('accounts'); if (rA) acc0 = JSON.parse(rA); } catch (e) { acc0 = null; }
        if (acc0 && !Array.isArray(acc0)) acc0 = null;
      }
      if (!Array.isArray(acc0) || acc0.length === 0) {
        acc0 = [
          { id: hotelGenIdEarly(), name: 'Admin User', email: 'admin@hotel.com', role: 'Admin', status: 'active' },
          { id: hotelGenIdEarly(), name: 'Jane Smith', email: 'jane@hotel.com', role: 'Receptionist', status: 'active' },
          { id: hotelGenIdEarly(), name: 'Mike Johnson', email: 'mike@hotel.com', role: 'Manager', status: 'active' },
          { id: hotelGenIdEarly(), name: 'Restaurant Staff', email: 'restaurant@hotel.com', role: 'Restaurant', status: 'active' },
          { id: hotelGenIdEarly(), name: 'Kitchen Staff', email: 'kitchen@hotel.com', role: 'Kitchen', status: 'active' },
          { id: hotelGenIdEarly(), name: 'Tom Williams', email: 'tom@hotel.com', role: 'Housekeeper', status: 'active' }
        ];
      }
      var em0 = String(email0).toLowerCase();
      if (!acc0.some(function (a) { return a && a.email && String(a.email).toLowerCase() === em0; })) {
        var n0 = em0.split('@')[0].replace(/[._-]/g, ' ').replace(/\b\w/g, function (c) { return c.toUpperCase(); });
        acc0.push({ id: hotelGenIdEarly(), name: n0, email: email0, role: 'Admin', status: 'active' });
      }
      try {
        if (isAn0 && typeof HotelDB.deleteAll === 'function' && typeof HotelDB.upsertAll === 'function') {
          HotelDB.deleteAll('accounts');
          HotelDB.upsertAll('accounts', JSON.stringify(acc0));
        } else {
          localStorage.setItem(K + 'accounts', JSON.stringify(acc0));
        }
      } catch (e2) {
        if (err0) err0.textContent = 'Could not save. Try again, or go Back to sign in and use a demo user.';
        return;
      }
      var so0 = document.getElementById('setupOverlay');
      var lo0 = document.getElementById('loginOverlay');
      try { sessionStorage.setItem('hotel_setup_prefill', JSON.stringify({ e: email0, p: pass0 })); } catch (e) {}
      if (err0) err0.textContent = '';
      try { location.reload(); } catch (e2) {}
    }
    /** Exposed for the main bundle: per-email storage namespace, setup flags, default accounts, then reload. */
    window.hotelRunCompleteSetupWithEmailPass = hotelCompleteSetupEarly;
    window.completeSetup = hotelCompleteSetupEarly;
    function accountIsActiveEarly(a) {
      if (!a) return false;
      if (a.status == null || a.status === '') return true;
      var st = String(a.status).toLowerCase();
      return st === 'active' || st === '1' || st === 'yes' || st === 'true';
    }
    function hotelDoLoginEarly() {
      var errE = document.getElementById('loginError');
      var uE = document.getElementById('loginUsername');
      var pE = document.getElementById('loginPassword');
      if (!uE || !pE) { if (errE) errE.textContent = 'Form not ready. Refresh the page (Ctrl+F5).'; return; }
      if (errE) errE.textContent = '';
      var un = (uE.value || '').trim().toLowerCase();
      var pw = pE.value || '';
      if (!un || !pw) { if (errE) errE.textContent = 'Please enter email and password'; return; }
      var isA = typeof HotelDB !== 'undefined';
      var accL = null;
