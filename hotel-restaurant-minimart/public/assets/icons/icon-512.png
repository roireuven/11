/** Display stored CreatedDate/EditDate (14-digit ymdHms or ISO) as yyyy/mm/dd -- HH:mm:ss in Excel-like grids. */
function xgridFormatStampCell(v) {
  if (v == null || v === '') return '';
  const s = String(v).trim();
  if (/^\d{14}$/.test(s)) {
    return s.slice(0, 4) + '/' + s.slice(4, 6) + '/' + s.slice(6, 8) + ' -- ' + s.slice(8, 10) + ':' + s.slice(10, 12) + ':' + s.slice(12, 14);
  }
  if (/^\d{4}-\d{2}-\d{2}/.test(s) || s.indexOf('T') >= 0) {
    try {
