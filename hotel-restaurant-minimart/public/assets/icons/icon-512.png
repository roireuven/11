    <div class="card"><div class="card-header"><h2>${t('settings.systemConfigCard')}</h2></div><div class="card-body">
      <h3 style="margin-bottom:1rem;font-size:1rem;">${t('settings.roomRatesSection')}</h3>
      <div class="form-row"><div class="form-group"><label>${t('settings.defaultTax')}</label><input type="number" class="form-control" id="sTaxRate" value="${s.taxRate||7}" step="0.1"></div><div class="form-group"><label>${t('settings.serviceTax')}</label><input type="number" class="form-control" id="sServiceTax" value="${s.serviceTax||7}" step="0.1"></div></div>
      <div class="form-row"><div class="form-group"><label>${t('settings.peakMul')}</label><input type="number" class="form-control" id="sPeakMul" value="${s.peakMultiplier||1.5}" step="0.1" min="1"></div><div class="form-group"><label>${t('settings.offMul')}</label><input type="number" class="form-control" id="sOffMul" value="${s.offMultiplier||0.8}" step="0.1" min="0.1"></div></div>
      <div class="form-row"><div class="form-group"><label>${t('settings.peakStart')}</label><input type="date" class="form-control" id="sPeakStart" value="${s.peakStart||'2026-06-01'}"></div><div class="form-group"><label>${t('settings.peakEnd')}</label><input type="date" class="form-control" id="sPeakEnd" value="${s.peakEnd||'2026-08-31'}"></div></div>
