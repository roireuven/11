    return new Date().toLocaleDateString((typeof l !== 'undefined' && l) ? undefined : 'en-US', { year: 'numeric', month: 'numeric', day: 'numeric' });
  } catch (e) {
    return new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'numeric', day: 'numeric' });
  }
}
