          if (isEditing && col.editable) {
            if (col.editType === 'select' && col.editOptions) {
              html += `<td><div class="cell editing"><select onchange="window._xg_${this.container.id}.commitEdit(${globalIdx},${ci},this.value)">`;
              col.editOptions.forEach(o => { html += `<option value="${o}" ${String(o) === String(val) ? 'selected' : ''}>${o}</option>`; });
              html += `</select></div></td>`;
            } else {
              const inputType = col.editType || 'text';
              html += `<td><div class="cell editing"><input type="${inputType}" value="${val}" onkeydown="if(event.key==='Enter'){event.preventDefault();window._xg_${this.container.id}.commitEdit(${globalIdx},${ci},this.value);}if(event.key==='Escape')window._xg_${this.container.id}.cancelEdit()"><button class="btn btn-sm btn-primary" style="margin-left:2px;padding:0.2rem 0.5rem;" onclick="var inp=this.previousElementSibling;window._xg_${this.container.id}.commitEdit(${globalIdx},${ci},inp.value)">✓</button></div></td>`;
            }
          } else {
            const tap = '';
            html += `<td><div class="cell" ${tap}>${displayVal}</div></td>`;
          }
        });
        if (this.actions.length) {
          html += `<td><div class="cell-actions">${this.actions.map(a => {
            if (a.condition && !a.condition(row)) return '';
            const _alb = xgridActionLabel(a);
            return `<button class="btn btn-sm ${a.cls || 'btn-outline'}" onclick="event.stopPropagation();window._xg_${this.container.id}.doAction('${a.name}','${row.id}')">${_alb}</button>`;
          }).join('')}</div></td>`;
        }
        html += `</tr>`;
      });
      if (this.summaryRow && filtered.length > 0) {
        const allData = this.getFiltered();
        const sumBg = document.body.classList.contains('dark-mode') ? '#1a2744' : '#f0f4fb';
        html += '<tr class="xgrid-summary-row" style="border-top:2px solid var(--text);font-weight:700;background:' + sumBg + ';">';
        this.columns.forEach(col => {
          if (col.hidden) return;
          const fn = this.summaryRow[col.field];
          if (fn === 'sum') {
            const total = allData.reduce((s, r) => s + (parseFloat(r[col.field]) || 0), 0);
            html += '<td><div class="cell">' + (col.format ? col.format(total, {}) : total.toFixed(2)) + '</div></td>';
          } else if (fn === 'count') {
            html += '<td><div class="cell">' + allData.length + '</div></td>';
          } else if (fn === 'label') {
            const _tot = typeof t === 'function' ? t('grid.total') : 'TOTAL';
            html += '<td><div class="cell" style="font-weight:700;">' + _tot + '</div></td>';
          } else {
            html += '<td><div class="cell"></div></td>';
          }
        });
        if (this.actions && this.actions.length) html += '<td></td>';
        html += '</tr>';
      }
    }
    html += `</tbody></table></div>`;
    const _pof = typeof t === 'function' ? t('grid.pageOf', { current: String(this.page + 1), total: String(totalPages) }) : ('Page ' + (this.page + 1) + ' of ' + totalPages);
    const _perOpts = [10, 15, 25, 50, 100].map(n => {
      const lab = typeof t === 'function' ? t('grid.perPage', { n: String(n) }) : (n + '/page');
      return `<option value="${n}" ${n === this.pageSize ? 'selected' : ''}>${lab}</option>`;
    }).join('');
    html += `<div class="xgrid-footer"><div>${_pof} &nbsp; <select onchange="window._xg_${this.container.id}.setPageSize(+this.value)">${_perOpts}</select></div>`;
    html += `<div class="xg-page-btns"><button ${this.page === 0 ? 'disabled' : ''} onclick="window._xg_${this.container.id}.goPage(0)">«</button><button ${this.page === 0 ? 'disabled' : ''} onclick="window._xg_${this.container.id}.goPage(${this.page - 1})">‹</button>`;
    for (let p = Math.max(0, this.page - 2); p < Math.min(totalPages, this.page + 3); p++) {
      html += `<button class="${p === this.page ? 'active' : ''}" onclick="window._xg_${this.container.id}.goPage(${p})">${p + 1}</button>`;
    }
    html += `<button ${this.page >= totalPages - 1 ? 'disabled' : ''} onclick="window._xg_${this.container.id}.goPage(${this.page + 1})">›</button><button ${this.page >= totalPages - 1 ? 'disabled' : ''} onclick="window._xg_${this.container.id}.goPage(${totalPages - 1})">»</button></div></div>`;
    this.container.innerHTML = html;
    window['_xg_' + this.container.id] = this;
    if (this.editingCell) { const inp = this.container.querySelector('.cell.editing input, .cell.editing select'); if (inp) inp.focus(); }
    if (activeMeta) {
      let toFocus = null;
      if (activeMeta.xg === 'master') toFocus = this.container.querySelector('input[data-xg="master"]');
      else if (activeMeta.xg === 'filter' && activeMeta.field) toFocus = this.container.querySelector('input[data-xg="filter"][data-xg-field="' + activeMeta.field.replace(/"/g, '&quot;') + '"]');
      if (toFocus) {
        try { toFocus.focus(); } catch (e) {}
        if (activeMeta.start != null && activeMeta.end != null) {
          try { toFocus.setSelectionRange(activeMeta.start, activeMeta.end); } catch (e2) {}
        }
      }
    }
    requestAnimationFrame(function() { window.scrollTo(0, winY); });
  }
  toggleSort(ci) { if (this.sortCol === ci) { this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc'; } else { this.sortCol = ci; this.sortDir = 'asc'; } this.render(); }
  setFilter(field, val) { this.filters[field] = val; this.page = 0; this.render(); }
  goPage(p) { this.page = Math.max(0, Math.min(p, this.getTotalPages() - 1)); this.render(); }
  setPageSize(n) { this.pageSize = n; this.page = 0; this.render(); }
  selectRow(idx) { this.selectedRow = this.selectedRow === idx ? null : idx; this.render(); }
  startEdit(row, col) { return; }
  commitEdit(row, col, val) {
    const filtered = this.getFiltered(); const dataRow = filtered[row];
    if (!dataRow) { this.cancelEdit(); return; }
    const field = this.columns[col].field; const oldVal = dataRow[field];
    if (this.columns[col].editType === 'number') val = parseFloat(val) || 0;
    dataRow[field] = val; this.editingCell = null;
    if (this.onEdit) this.onEdit(dataRow, field, val, oldVal);
    this.render();
  }
  cancelEdit() { this.editingCell = null; this.render(); }
  doAction(name, id) {
    const action = this.actions.find(a => a.name === name);
    if (action && action.handler) action.handler(id);
  }
}

// ===== AUTO-ID GENERATORS =====
function nextOrderNumber() {
  const nums = restaurantOrders.map(o => parseInt((o.orderNumber||'').replace('RO-',''))).filter(n=>!isNaN(n));
  return 'RO-' + (Math.max(1000, ...nums) + 1);
}
function nextBookingId() {
  const nums = bookings.map(b => parseInt((b.bookingId||'').replace('BK-',''))).filter(n=>!isNaN(n));
  return 'BK-' + (Math.max(1000, ...nums) + 1);
}
function nextInvoiceNumber() {
  const nums = invoices.map(i => parseInt((i.invoiceNumber||'').replace('INV-',''))).filter(n=>!isNaN(n));
  return 'INV-' + (Math.max(2000, ...nums) + 1);
}
function nextTransactionId() {
  const nums = transactions.map(t => parseInt((t.transactionId||'').replace('TXN-',''))).filter(n=>!isNaN(n));
  return 'TXN-' + (Math.max(10000, ...nums) + 1);
}

// ===== AUDIT LOG =====
let currentRole = 'Admin';
let currentUser = null;
function renderChangeLog(containerId, moduleName) {
  const names = Array.isArray(moduleName) ? moduleName.map(n=>n.toLowerCase()) : [moduleName.toLowerCase()];
  const filtered = auditLog.filter(a => { const m = (a.module||a.entity||'').toLowerCase(); return names.some(n => m===n || m.includes(n)); });
  new XGrid(containerId, {
    columns: [
      {field:'timestamp',label:typeof t==='function'?t('g.timestamp'):'Timestamp',format:v=>{try{const d=new Date(v);return d.toLocaleDateString('en-US',{month:'short',day:'numeric'})+' '+d.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});}catch(e){return v;}},filterable:true,width:'130px'},
      {field:'module',label:typeof t==='function'?t('g.module'):'Module',filterable:true,width:'80px'},
      {field:'user',label:typeof t==='function'?t('g.user'):'User',filterable:true,width:'80px'},
      {field:'action',label:typeof t==='function'?t('g.action'):'Action',filterable:true,width:'80px'},
      {field:'itemId',label:typeof t==='function'?t('g.itemId'):'Item ID',filterable:true,width:'100px'},
      {field:'items',label:typeof t==='function'?t('g.items'):'Items',filterable:true,width:'160px'},
      {field:'details',label:typeof t==='function'?t('g.details'):'Details',filterable:true},
    ],
    data: filtered,
    emptyMessage: typeof t==='function'?t('logs.emptyChanges'):'▲ No changes recorded yet',
    trackVisible: false
  });
}
function logAudit(action, tableName, recordId, details, itemsLine) {
  if (details === undefined) { details = recordId; recordId = ''; }
  const userName = currentUser ? currentUser.name : (currentRole || 'Admin');
  const _adTs = ymdHmsNow();
  const entry = {id:genId(), timestamp:new Date().toISOString(), module:tableName, user:userName, action:action, itemId:String(recordId), items:(itemsLine == null ? '' : String(itemsLine)), details:String(details||''), CreatedDate: _adTs, EditDate: _adTs};
  auditLog.push(entry);
  if (auditLog.length > 2000) auditLog = auditLog.slice(-2000);
  if (isAndroid) {
    try { HotelDB.upsert('audit_log', JSON.stringify(entry)); } catch(e) {}
  } else {
    try { localStorage.setItem(DB_KEY + 'auditLog', JSON.stringify(auditLog)); } catch(e) {}
  }
}

