      save('menuItems', menuItems);
    }
    if (Array.isArray(storeItems)) {
      storeItems.forEach(function (s) { if (s && s.inventoryItemId) delete s.inventoryItemId; });
      save('storeItems', storeItems);
    }
    try { localStorage.setItem(MK, '1'); } catch (e) {}
