  exportCSV() {
    const rows = this.getFiltered();
    const strip = s => String(s).replace(/<[^>]*>/g, '').trim();
    const hdr = (this.columns.filter(c => !c.hidden).map(c => '"' + String(xgridColLabel(c)).replace(/"/g, '""') + '"')).join(',');
    const body = rows.map(r => this.columns.filter(c => !c.hidden).map(c => {
