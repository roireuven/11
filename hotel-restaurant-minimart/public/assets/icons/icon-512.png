  var b = document.getElementById('langMenuBtn');
  if (b) b.setAttribute('aria-expanded', 'false');
  applyShellI18n();
  syncLangMenuHighlight();
  var lo = document.getElementById('loginOverlay');
  if (lo && !lo.classList.contains('hidden')) return;
