    "cashCharged": "Charged",
    "cashLabelChangeDue": "Change due:",
    "cashLabelStillNeed": "Still need:",
    "cashKeypadHint": "Use the keypad to enter cash received. Change shows above.",
    "cashConfirm": "Confirm cash",
    "cashAll": "All",
    "invoiceCashTitle": "Invoice — Cash ({n})",
    "serviceReqCashTitle": "Service — Cash ({name})",
    "payWithCash": "Pay with cash",
