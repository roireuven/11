/** System walk-in / walk-by guest: fixed id; do not remove (see isSystemWalkByGuest). */
const WALK_BY_GUEST_ID = 'walk-by-system-guest';
function isSystemWalkByGuest(g) { return g && (g.id === WALK_BY_GUEST_ID || g.isSystemWalkBy === true); }
function isWalkByReservedNamePair(firstName, lastName) {
  const fn = String(firstName == null ? '' : firstName).trim().toLowerCase();
  const ln = String(lastName == null ? '' : lastName).trim().toLowerCase();
  return fn === 'walk by' && ln === 'walk by';
}
function sortGuestsWalkByFirst(list) {
  if (!Array.isArray(list) || !list.length) return list || [];
  const w = list.findIndex(isSystemWalkByGuest);
  if (w <= 0) return list.slice();
  const out = list.slice();
  out.splice(w, 1);
  out.unshift(list[w]);
  return out;
}
function ensureSystemWalkByGuest() {
  if (!Array.isArray(guests)) return false;
  var changed = false;
  function isWalkByNamePair(g) {
    if (!g) return false;
    if (isWalkByReservedNamePair(g.firstName, g.lastName)) return true;
    const fn = String(g.firstName).trim().toLowerCase();
    const ln = String(g.lastName).trim().toLowerCase();
    return fn === '. walk by' && ln === '. walk by';
  }
  var w = guests.findIndex(function (g) { return g && (g.id === WALK_BY_GUEST_ID || g.isSystemWalkBy || isWalkByNamePair(g)); });
  if (w < 0) {
    guests.unshift({ id: WALK_BY_GUEST_ID, firstName: 'walk by', lastName: 'walk by', passportId: '', nationality: '', dob: '', email: 'walkby@local', phone: '', paymentMethod: 'Cash', guestNotes: 'System: walk-by guest (not editable, not deletable).', blacklist: 0, visits: 0, isSystemWalkBy: true });
    return true;
  }
  const g = guests[w];
  if (g.id !== WALK_BY_GUEST_ID || g.firstName !== 'walk by' || g.lastName !== 'walk by' || !g.isSystemWalkBy) changed = true;
  g.id = WALK_BY_GUEST_ID;
  g.firstName = 'walk by';
  g.lastName = 'walk by';
  g.isSystemWalkBy = true;
  for (var j = guests.length - 1; j >= 0; j--) {
    if (j === w) continue;
    const x = guests[j];
    if (x && !isSystemWalkByGuest(x) && isWalkByNamePair(x)) { guests.splice(j, 1); if (j < w) w--; changed = true; }
  }
  w = guests.findIndex(isSystemWalkByGuest);
  if (w > 0) { const g0 = guests.splice(w, 1)[0]; guests.unshift(g0); changed = true; }
  return changed;
}
function normalizeGuestsOrderInPlace() {
  if (!Array.isArray(guests)) return;
  const w = guests.findIndex(isSystemWalkByGuest);
  if (w > 0) { const g0 = guests.splice(w, 1)[0]; guests.unshift(g0); }
}
