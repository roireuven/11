      <div class="form-row"><div class="form-group"><label>${t('settings.hotelName')}</label><input type="text" class="form-control" id="sName" value="${s.hotelName}"></div><div class="form-group"><label>${t('settings.contactEmail')}</label><input type="email" class="form-control" id="sEmail" value="${s.email}"></div></div>
      <div class="form-row"><div class="form-group"><label>${t('settings.phoneNumber')}</label><input type="tel" class="form-control" id="sPhone" value="${s.phone}"></div><div class="form-group"><label>${t('settings.currency')}${adminEditBtn('currencyLabels')}</label><select class="form-control" id="sCurrency" data-native-select="1">${getCurrencyLabels().map(c=>`<option ${c===s.currency?'selected':''}>${c}</option>`).join('')}</select></div></div>
      ${lakLaoRow}
      <div class="form-group"><label>${t('settings.address')}</label><input type="text" class="form-control" id="sAddr" value="${s.address}"></div>
      <h3 style="margin:1.5rem 0 1rem;font-size:1rem;">${t('settings.regulations')}</h3>
      <div class="form-row"><div class="form-group"><label>${t('settings.maxGuests')}</label><input type="number" class="form-control" id="sMaxG" value="${s.maxGuests}"></div><div class="form-group"><label>${t('settings.surcharge')}</label><input type="number" class="form-control" id="sSur" value="${s.surcharge}"></div></div>
      <div class="form-row"><div class="form-group"><label>${t('settings.checkin')}</label><input type="time" class="form-control" id="sIn" value="${s.checkinTime}"></div><div class="form-group"><label>${t('settings.checkout')}</label><input type="time" class="form-control" id="sOut" value="${s.checkoutTime}"></div></div>
      <div style="margin-top:1rem;"><button class="btn btn-primary" style="width:100%;justify-content:center;padding:0.75rem;" onclick="saveSettings()">${t('settings.saveSettings')}</button></div>
