  const phNew = t('ui2.phNewListValue');
  const escQ = (s) => String(s).replace(/\\/g,'\\\\').replace(/'/g, "\\'").replace(/</g, '&lt;');
  const rowTpl = escQ("<div style='display:flex;gap:0.5rem;align-items:center;margin-bottom:0.5rem;'> <input type='text' class='form-control list-val' placeholder='" + phNew.replace(/'/g, "&#39;") + "' style='flex:1;'><button class='btn btn-sm btn-danger' onclick='this.parentElement.remove()' style='min-width:36px;'>✕</button></div>");
  let html = '<div class="modal-header"><h2>' + t('ui2.manageListTitle', { label: label }) + '</h2><button class="modal-close" onclick="closeModal()">&times;</button></div>' +
    '<div class="modal-body">' +
    '<p style="font-size:0.85rem;color:var(--text-light);margin-bottom:1rem;">' + t('ui2.listEditorHint') + '</p>' +
    '<div id="listItems">';
