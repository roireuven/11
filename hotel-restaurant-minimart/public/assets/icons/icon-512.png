      const arrow = isSort ? (this.sortDir === 'asc' ? '\u25B2' : '\u25BC') : '\u21C5';
      const _cLab = xgridColLabel(col);
      html += `<th style="${col.width ? 'width:' + col.width : ''}"><div class="th-inner" onclick="window._xg_${this.container.id}.toggleSort(${ci})"><span>${_cLab}</span><span class="sort-icon ${isSort ? 'active' : ''}">${arrow}</span></div>`;
      if (col.filterable !== false) {
        const _fl = typeof t === 'function' ? t('grid.filterLabel', { col: String(_cLab) }) : ('Filter ' + _cLab);
        html += `<input class="col-filter" data-xg="filter" data-xg-field="${String(col.field).replace(/"/g, '&quot;')}" placeholder="${String(_fl).replace(/"/g, '&quot;')}" value="${this.filters[col.field] || ''}" oninput="window._xg_${this.container.id}.setFilter('${col.field}',this.value)">`;
      }
