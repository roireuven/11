  return getHotelCurrencySymbol() + num.toFixed(2);
}
/** Multi-term search: every token must appear in haystack (e.g. "we 88" → room 88 + Wei). */
function guestQueryMatches(hay, q) {
  if (q == null) return true;
  var s = String(q).toLowerCase().trim();
  if (!s) return true;
  var h = ' ' + String(hay == null ? '' : hay).toLowerCase() + ' ';
  var terms = s.split(/\s+/).filter(Boolean);
  for (var t = 0; t < terms.length; t++) { if (h.indexOf(terms[t]) < 0) return false; }
  return true;
}
function findGuestByBookingGuestName(guestName) {
  if (!guestName || typeof guests === 'undefined' || !Array.isArray(guests) || !guests.length) return null;
  var want = String(guestName).trim().toLowerCase().replace(/\s+/g, ' ');
  if (typeof isSystemWalkByGuest === 'function') {
    var sysW = guests.find(isSystemWalkByGuest);
    if (sysW) {
      var sf = (String(sysW.firstName) + ' ' + String(sysW.lastName)).trim().toLowerCase().replace(/\s+/g, ' ');
      if (want === sf || want === 'walk by' || want === 'walk by walk by') return sysW;
    }
  }
  for (var i = 0; i < guests.length; i++) {
    var g = guests[i];
    var full = (String(g.firstName) + ' ' + String(g.lastName)).trim().toLowerCase();
    if (full === want) return g;
  }
  for (i = 0; i < guests.length; i++) {
    g = guests[i];
    var fn = String(g.firstName).toLowerCase();
    var ln = String(g.lastName).toLowerCase();
    if (fn && want.indexOf(fn) >= 0 && ln && want.indexOf(ln) >= 0) return g;
  }
  return null;
}
function buildRoomServiceGuestSearchHay(b) {
  var base = (String(b.roomNumber) + ' ' + String(b.guestName) + ' ' + String(b.bookingId) + ' ' + (b.roomType || '')).toLowerCase();
  var g = findGuestByBookingGuestName(b.guestName);
  if (!g) return base;
  var extra = [g.email, g.phone, g.passportId, (typeof guestDisplayId === 'function' ? guestDisplayId(g) : ''), (g.nationality || ''), (g.dob || '')]
    .map(function(x) { return String(x || '').toLowerCase(); }).join(' ');
  if (g.guestNotes) extra += ' ' + String(g.guestNotes).toLowerCase();
  if (parseInt(g.blacklist, 10)) extra += ' blacklist';
  if ((parseInt(g.visits, 10) || 0) >= 4) extra += ' frequent return';
  if ((String(g.guestNotes || '').toLowerCase().indexOf('vip') >= 0)) extra += ' vip';
  return (base + ' ' + extra).replace(/\s+/g, ' ').trim();
}
function buildGuestDirectorySearchHay(g) {
  if (!g) return '';
  var base = [g.firstName, g.lastName, g.passportId, g.email, g.phone, (typeof guestDisplayId === 'function' ? guestDisplayId(g) : ''), (g.nationality || ''), (g.dob || ''), (g.guestNotes || '')]
    .map(function(x) { return String(x || ''); }).join(' ').toLowerCase();
  if (parseInt(g.blacklist, 10)) base += ' blacklist';
  if (String(g.guestNotes || '').toLowerCase().indexOf('vip') >= 0) base += ' vip';
  if ((parseInt(g.visits, 10) || 0) >= 4) base += ' frequent return';
  return base.replace(/\s+/g, ' ').trim();
}
function filterRestGuestCardGrid(inputId) {
  var el = document.getElementById(inputId);
  var v = el ? el.value : '';
  var id = (inputId === 'martGuestSearch') ? 'martGuestCards' : 'restGuestCards';
  var root = document.getElementById(id);
  if (!root) return;
