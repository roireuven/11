  if (!Array.isArray(menuItems)) return;
  var ch = false;
  menuItems.forEach(function(m) {
    if (!m) return;
    if (m.imageUrl != null && menuItemImageUrlIsStockOrDemoRemote(m.imageUrl)) { m.imageUrl = ''; ch = true; }
    if (m.image != null && String(m.image).indexOf('http') === 0 && menuItemImageUrlIsStockOrDemoRemote(m.image)) { m.image = ''; ch = true; }
  });
  if (ch) { try { save('menuItems', menuItems); } catch (e) {} }
  try { localStorage.setItem(MK, '1'); } catch (e) {}
  if (isAndroid) { try { HotelDB.saveSetting('menuStripStockHttpImgV1', '1'); } catch (e) {} }
