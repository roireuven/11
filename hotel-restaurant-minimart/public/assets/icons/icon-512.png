    const addBtn = this.onAdd ? `<button class="btn btn-sm btn-primary" onclick="window._xg_${this.container.id}.onAdd()">+ ${_al}</button>` : '';
    const ex = typeof t === 'function' ? t('grid.exportCsv') : 'EXPORT CSV';
    const im = typeof t === 'function' ? t('grid.importCsv') : 'IMPORT CSV';
    const exportBtn = this.hideExport ? '' : `<button class="btn btn-sm btn-outline" onclick="window._xg_${this.container.id}.exportCSV()">${ex}</button>`;
    const importBtn = (this.hideExport || !this.onImport) ? '' : `<button class="btn btn-sm btn-outline" onclick="document.getElementById('csvImp_${this.container.id}').click()">${im}</button><input type="file" id="csvImp_${this.container.id}" accept=".csv" style="display:none" onchange="window._xg_${this.container.id}.importCSV(this)">`;
    const _tglH = typeof t === 'function' ? t(this.showHiddenRows ? 'grid.toggleHiddenOff' : 'grid.toggleHiddenOn') : (this.showHiddenRows ? 'Hide hidden rows' : 'Toggle hidden rows');
    const toggleHiddenBtn = this.trackVisible ? `<button type="button" class="btn btn-sm btn-outline" onclick="window._xg_${this.container.id}.toggleHiddenRows()">${_tglH}</button>` : '';
    let html = '';
