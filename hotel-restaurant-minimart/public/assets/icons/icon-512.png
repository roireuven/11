    "workPeriodOpenCta": "Start shift",
    "workPeriodStarted": "Work period started.",
    "workPeriodCloseTitle": "Close work period",
    "workPeriodSummaryIntro": "Review this shift's totals, then count the physical cash in the drawer.",
    "cashInDrawerTheory": "Expected drawer (theory)",
    "cashSalesInPeriod": "Cash sales this period",
