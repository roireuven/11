    '<div class="modal-footer"><button class="btn btn-outline" onclick="closeModal()">' + t('common.cancel') + '</button><button class="btn btn-primary" onclick="saveList(\'' + String(listName).replace(/'/g, "\\'") + '\')">' + t('common.save') + '</button></div>';
  openModal(html);
};
window.saveList = function(listName) {
  const inputs = document.querySelectorAll('#listItems .list-val');
  const values = [];
  inputs.forEach(inp => { const v = inp.value.trim(); if(v) values.push(v); });
  if(values.length === 0) { toast(t('msg.addOneValue')); return; }
  settings[listName] = values.join(',');
  save('settings', settings);
  logAudit('Update','Settings','Updated '+listName+': '+values.join(', '));
  closeModal();
  toast(t('msg.listLabelUpdated', { label: tDdlName(listName) }));
