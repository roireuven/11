rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Guest QR orders — propertyNs (from staff setup email hash) is the tenant key.
    // Treat propertyNs as a secret; orders are readable without auth so staff devices can sync.
    match /guestQrOrders/{propertyNs}/orders/{orderId} {
      allow create: if request.resource.data.propertyNs == propertyNs
        && request.resource.data.dept in ['restaurant', 'minimart']
        && request.resource.data.status == 'pending'
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 80
        && request.resource.data.grandTotal is number
        && request.resource.data.grandTotal >= 0
        && request.resource.data.grandTotal <= 1000000
        && (!('orderNum' in request.resource.data)
          || (request.resource.data.orderNum is int
            && request.resource.data.orderNum >= 1
            && request.resource.data.orderNum <= 60));
      allow read: if resource.data.propertyNs == propertyNs;
      allow update: if resource.data.propertyNs == propertyNs
        && request.resource.data.propertyNs == propertyNs
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'syncedAt', 'syncedBy'])
        && request.resource.data.status in ['pending', 'accepted', 'completed', 'cancelled', 'paid', 'synced'];
      allow delete: if false;
    }
  }
}
